{
  "defaults": {
    "profileGroupName": "Crispy Profile Group",
    "profileName": "Main"
  },
  "cache": {
    "homeTtlSeconds": 120,
    "calendarTtlSeconds": 300,
    "tmdb": {
      "movieTtlHours": 168,
      "showTtlHours": 24,
      "seasonTtlHours": 24
    }
  },
  "metadata": {
    "tmdb": {
      "baseUrl": "https://api.themoviedb.org/3",
      "imageBaseUrl": "https://image.tmdb.org/t/p"
    }
  },
  "ai": {
    "byokOpenRouter": {
      "models": {
        "recommendations": "openai/gpt-4o-mini",
        "search": "openai/gpt-4o-mini",
        "insights": "openai/gpt-4o-mini"
      }
    },
    "server": {
      "id": "server-ai",
      "label": "Server AI",
      "endpointUrl": "https://your-server-ai-provider.example.com/v1/chat/completions",
      "models": {
        "pro": {
          "recommendations": "provider/pro-model",
          "search": "provider/pro-model",
          "insights": "provider/pro-model"
        },
        "ultra": {
          "recommendations": "provider/ultra-model",
          "search": "provider/ultra-model",
          "insights": "provider/ultra-model"
        }
      }
    }
  }
}
