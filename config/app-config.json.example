{
  "defaults": {
    "profileGroupName": "Crispy Profile Group",
    "profileName": "Main"
  },
  "cache": {
    "homeTtlSeconds": 120,
    "calendarTtlSeconds": 300,
    "tmdb": {
      "movieTtlHours": 168,
      "showTtlHours": 12,
      "seasonTtlHours": 12
    }
  },
  "metadata": {
    "tmdb": {
      "baseUrl": "https://api.themoviedb.org/3",
      "imageBaseUrl": "https://image.tmdb.org/t/p"
    }
  },
  "ai": {
    "byokOpenRouter": {
      "models": {
        "recommendations": "minimax/minimax-m2.5:free",
        "search": "google/gemma-4-31b-it:free",
        "insights": "google/gemma-4-31b-it:free"
      }
    },
    "server": {
      "id": "server-ai",
      "label": "Server AI",
      "endpointUrl": "https://omnirouter.aayushcodes.eu/v1/chat/completions",
      "models": {
        "pro": {
          "recommendations": "gpt5mini",
          "search": "gpt5mini",
          "insights": "gpt5mini"
        },
        "ultra": {
          "recommendations": "gpt5mini",
          "search": "gpt5mini",
          "insights": "gpt5mini"
        }
      }
    }
