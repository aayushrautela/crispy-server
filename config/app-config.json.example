{
  "defaults": {
    "profileGroupName": "Crispy Profile Group",
    "profileName": "Main"
  },
  "cache": {
    "homeTtlSeconds": 120,
    "calendarTtlSeconds": 300,
    "tmdb": {
      "movieTtlHours": 168,
      "showTtlHours": 24,
      "seasonTtlHours": 24
    }
  },
  "metadata": {
    "tmdb": {
      "baseUrl": "https://api.themoviedb.org/3",
      "imageBaseUrl": "https://image.tmdb.org/t/p"
    }
  },
  "ai": {
    "defaultProviderId": "openrouter",
