# Environment configuration
NODE_ENV=development

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=18765
LOG_LEVEL=info

# Admin UI credentials
ADMIN_UI_USER=admin
ADMIN_UI_PASSWORD=change-me
ADMIN_UI_SESSION_SECRET=replace_with_long_random_secret

# Database connection
DATABASE_URL=postgres://crispy:crispy@postgres:5432/crispy

# Redis connection
REDIS_URL=redis://redis:6379

# Application settings
APP_PUBLIC_URL=https://api.crispytv.tech
APP_DISPLAY_NAME=CrispyTV

# Supabase authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=
AUTH_JWT_AUDIENCE=authenticated

# External API keys
TMDB_API_KEY=your_tmdb_api_key
MDBLIST_API_KEY=

# AI server-funded credential.
# Server key is used for pro/ultra tier AI features. BYOK users provide their own OpenRouter keys.
AI_SERVER_API_KEY=replace_with_server_funded_ai_key

# Trakt.tv import integration
TRAKT_IMPORT_CLIENT_ID=
TRAKT_IMPORT_CLIENT_SECRET=
TRAKT_IMPORT_REDIRECT_URI=

# SIMKL import integration
SIMKL_IMPORT_CLIENT_ID=
SIMKL_IMPORT_CLIENT_SECRET=
SIMKL_IMPORT_REDIRECT_URI=

# Recommendation engine settings
RECOMMENDATION_ALGORITHM_VERSION=v3.2.1
RECOMMENDATION_GENERATION_TTL_SECONDS=86400
RECOMMENDATION_GENERATION_QUEUE_DELAY_MS=5000

# Service clients configuration (JSON array)
# Internal app principals use /internal/apps/v1 and confidential config uses /internal/confidential/v1.
# Include confidential-config:ai-config:read scope for clients fetching private AI config bundles.
SERVICE_CLIENTS_JSON=[{"serviceId":"crispy-recommendation-engine","apiKey":"replace_with_long_random_secret","scopes":["confidential-config:ai-config:read"],"status":"active"}]
