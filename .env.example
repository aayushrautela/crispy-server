NODE_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=18765
LOG_LEVEL=info
ADMIN_UI_USER=admin
ADMIN_UI_PASSWORD=change-me
ADMIN_UI_SESSION_SECRET=replace_with_long_random_secret
DATABASE_URL=postgres://crispy:crispy@postgres:5432/crispy
REDIS_URL=redis://redis:6379
APP_PUBLIC_URL=https://api.crispytv.tech
APP_DISPLAY_NAME=CrispyTV
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=
AUTH_JWT_AUDIENCE=authenticated
TMDB_API_KEY=your_tmdb_api_key
TVDB_API_KEY=your_tvdb_api_key
TVDB_PIN=
MDBLIST_API_KEY=
AI_SERVER_KEYS_JSON=[]
TRAKT_IMPORT_CLIENT_ID=
TRAKT_IMPORT_CLIENT_SECRET=
TRAKT_IMPORT_REDIRECT_URI=
SIMKL_IMPORT_CLIENT_ID=
SIMKL_IMPORT_CLIENT_SECRET=
SIMKL_IMPORT_REDIRECT_URI=
# From the server container, use the shared Docker network alias.
# Do not use 127.0.0.1 here unless both services run in the same container.
RECOMMENDATION_ENGINE_WORKER_BASE_URL=http://recommendation-worker:3000
RECOMMENDATION_ENGINE_WORKER_API_KEY=
RECOMMENDATION_ENGINE_WORKER_SERVICE_ID=
RECOMMENDATION_ALGORITHM_VERSION=v3.2.1
RECOMMENDATION_GENERATION_TTL_SECONDS=86400
RECOMMENDATION_GENERATION_QUEUE_DELAY_MS=5000
RECOMMENDATION_ENGINE_WORKER_SUBMIT_TIMEOUT_MS=15000
RECOMMENDATION_ENGINE_WORKER_STATUS_TIMEOUT_MS=15000
RECOMMENDATION_GENERATION_POLL_DELAY_MS=15000
RECOMMENDATION_GENERATION_MAX_POLL_DELAY_MS=120000
# Internal service clients authenticate with x-service-id and x-api-key headers.
# Recommendation engines should use app principal auth via /internal/apps/v1 instead of legacy service auth.
# Include confidential-config:ai-config:read scope for clients fetching private AI config bundles.
# Example legacy service client (deprecated for RECO):
SERVICE_CLIENTS_JSON=[{"serviceId":"crispy-recommendation-engine","apiKey":"replace_with_long_random_secret","scopes":["confidential-config:ai-config:read"],"status":"active"}]
