{
  "name": "crispy-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/bin/api.ts",
    "dev:worker": "tsx watch src/bin/worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "migrate": "tsx scripts/migrate.ts",
    "backfill:watch-projections": "tsx scripts/backfill-watch-projections.ts",
    "migrate:prod": "node dist/scripts/migrate.js",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "start:api": "node dist/src/bin/api.js",
    "start:worker": "node dist/src/bin/worker.js"
  },
  "dependencies": {
    "bullmq": "^5.56.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "pg": "^8.16.3",
    "pino": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
