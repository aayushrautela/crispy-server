# Environment configuration
NODE_ENV=production

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=18765
LOG_LEVEL=info

# Admin UI credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_UI_USER=admin
ADMIN_UI_PASSWORD=change-me
ADMIN_UI_SESSION_SECRET=replace_with_long_random_secret

# Database configuration
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://crispy:change-me@postgres:5432/crispy

# Redis connection
REDIS_URL=redis://redis:6379

# Application settings
APP_PUBLIC_URL=https://api.crispytv.tech
APP_DISPLAY_NAME=CrispyTV

# Supabase authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=
AUTH_JWT_AUDIENCE=authenticated

# External API keys
TMDB_API_KEY=your_tmdb_api_key
MDBLIST_API_KEY=

# AI server-funded credentials (JSON array of API keys).
# Server keys are used for pro/ultra tier AI features. BYOK users provide their own OpenRouter keys.
# Format: [{"apiKey":"your_server_ai_key"}] or legacy [{"providerId":"provider-id","apiKey":"key"}]
AI_SERVER_KEYS_JSON=[{"apiKey":"replace_with_server_funded_ai_key"}]

# Trakt.tv import integration
TRAKT_IMPORT_CLIENT_ID=
TRAKT_IMPORT_CLIENT_SECRET=
TRAKT_IMPORT_REDIRECT_URI=

# SIMKL import integration
SIMKL_IMPORT_CLIENT_ID=
SIMKL_IMPORT_CLIENT_SECRET=
SIMKL_IMPORT_REDIRECT_URI=

# Recommendation engine settings
RECOMMENDATION_ALGORITHM_VERSION=v3.2.1
RECOMMENDATION_GENERATION_TTL_SECONDS=86400
RECOMMENDATION_GENERATION_QUEUE_DELAY_MS=5000

# Service clients configuration (JSON array with full scope access for internal tools)
SERVICE_CLIENTS_JSON=[{"serviceId":"crispy-internal-tool","apiKey":"replace_with_long_random_secret","scopes":["profiles:read","watch:read","taste-profile:read","taste-profile:write","recommendations:read","recommendations:write","profile-secrets:read","provider-connections:read","provider-tokens:read","provider-tokens:refresh","admin:diagnostics:read"],"status":"active"}]
